{
  "variable": {
    "MESSAGE": {
      "default": "hello-from-bake"
    },
    "HUGO_VERSION": {
      "default": "0.147.1"
    },
    "AUTOPREFIXER_VERSION": {
      "default": "10.4.21"
    }
  },
  "target": {
    "app": {
      "context": ".",
      "dockerfile": "Dockerfile",
      "args": {
        "MESSAGE": "${MESSAGE}"
      },
      "tags": [
        "registry.example.local/container-images/bake:${HUGO_VERSION}-${AUTOPREFIXER_VERSION}"
      ]
    }
  }
}
